{
  "editor.inlineSuggest.enabled": false,
  "java.configuration.maven.userSettings": "${workspaceFolder}/.maven/settings.xml",
  "java.format.settings.url": "${workspaceFolder}/.vscode/java-formatter.xml",
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.format.settings.profile": "poc",
  "editor.inlayHints.enabled": "off",
  "cSpell.words": [
    "aftersale",
    "amqp",
    "Amqp",
    "confluentinc",
    "cpus",
    "databind",
    "declarables",
    "fasterxml",
    "github",
    "healthcheck",
    "isometricgame",
    "jackson",
    "lombok",
    "mongodb",
    "nginx",
    "oder",
    "openfeign",
    "poststart",
    "projectlombok",
    "rabbitmq",
    "springframework",
    "throyer",
    "verygeneric"
  ],
  "java.compile.nullAnalysis.mode": "disabled",
  "[java]": {
    "editor.tabSize": 2,
    "editor.indentSize": 2,
    "editor.defaultFormatter": "redhat.java"
  },
}